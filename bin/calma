#!/usr/bin/env bash
# calma - thin launcher for the pure-stdlib verifier.
# Install:  ln -s "$(pwd)/bin/calma" /usr/local/bin/calma   (or add this repo's bin/ to PATH)
set -euo pipefail
SELF_DIR="$(python3 -c 'import os, sys; print(os.path.dirname(os.path.realpath(sys.argv[1])))' "${BASH_SOURCE[0]}")"
exec python3 "$SELF_DIR/../.claude/skills/calma/scripts/calma.py" "$@"
