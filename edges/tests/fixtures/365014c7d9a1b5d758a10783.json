                          "string",
                          "null"
                        ],
                        "description": "a code/function reference, e.g. 'sklearn.metrics.roc_auc_score'"
                      },
                      "formula_hint": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "description": "the formula the author implies, e.g. 'TP/(TP+FP)', '(end/start)-1'"
                      }
                    }
                  },
                  "source_span": {
                    "type": "object",
                    "required": [
                      "quote",
                      "element_type"
                    ],
                    "additionalProperties": false,
                    "properties": {
                      "quote": {
                        "type": "string",
