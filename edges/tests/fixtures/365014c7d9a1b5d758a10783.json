                            },
                            "minItems": 4,
                            "maxItems": 4
                          }
                        ]
                      },
                      "element_type": {
                        "enum": [
                          "code",
                          "output",
                          "markdown",
                          "paragraph",
                          "table",
                          "caption",
                          "figure"
                        ]
                      },
                      "section": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "description": "'cell 14', 'Table 2', a heading"
                      }
                    }
                  },
                  "confidence": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1,
                    "description": "the model's self-rated EXTRACTION confidence (not correctness of the number) -- drives the P1.5 router"
                  }
                }
              }
            }
          }
        }
      }
    ],
