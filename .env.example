# Calma control-plane env template (SAFE to commit — no secrets; .gitignore keeps the real .env out).
# Copy to .env and fill in. The deployed side uses `vercel env` instead.

# Execution isolation (SECURITY). The control plane runs SUBMITTED code and must never execute it
# unisolated on the API host. In production set CALMA_EXEC_ISOLATION=e2b so every run goes to a verified
# Firecracker microVM; CALMA_REQUIRE_ISOLATED defaults ON when VERCEL_ENV=production, which makes the
# engine REFUSE (rather than degrade to an unwrapped host run) when no verified tier is achievable.
# Leave both unset on a dev host with a working local sandbox (macOS seatbelt / Linux bwrap).
CALMA_EXEC_ISOLATION=               # ""|auto (dev) | e2b | docker | firecracker  (prod: e2b)
CALMA_REQUIRE_ISOLATED=             # ""=auto (on in prod) | 1 force-on | 0 force-off

# E2B — hosted Firecracker execution (read by run_hermetic._e2b_config)
CALMA_E2B_API_KEY=
CALMA_E2B_ENDPOINT=e2b.dev
CALMA_E2B_TEMPLATE=base

# Supabase / Postgres — control-plane DB
SUPABASE_URL=
SUPABASE_ANON_KEY=
DATABASE_URL=                      # Postgres connection string (URI, with password) — server-side + migrations
SUPABASE_SERVICE_ROLE_KEY=         # service_role secret — server-side only

# Cloudflare R2 — object storage (input bundles / artifacts / proofs)
R2_ENDPOINT=
R2_BUCKET=
R2_REGION=auto
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# WorkOS — auth / SSO
WORKOS_CLIENT_ID=
WORKOS_API_KEY=

# Stripe — billing (later)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# control-plane API <-> dashboard (first-party)
CALMA_API_URL=http://localhost:8000
CALMA_SERVICE_TOKEN=

# verification API (spike/server.py) <-> dashboard (first-party). The "Verify a repo" flow in the gated
# dashboard proxies submissions here server-side. dev: run `./spike/web.sh` (defaults to :8787). In prod,
# point CALMA_VERIFY_API_URL at the deployed verification service (Vercel can't reach a laptop's localhost).
# CALMA_VERIFY_TOKEN gates the API: when SET the backend is first-party-only (the dashboard sends it); when
# UNSET the API stays open for the local-first operator (the SPA at :8787). Falls back to CALMA_SERVICE_TOKEN.
CALMA_VERIFY_API_URL=http://localhost:8787
CALMA_VERIFY_TOKEN=

# WorkOS AuthKit (dashboard login)
WORKOS_COOKIE_PASSWORD=                # 32+ chars
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback
DASHBOARD_DEV_TENANT_ID=               # optional: run the dashboard without the interactive WorkOS flow

# ed25519 proof-signing private key (base64 of the 32-byte seed). Generate with control_plane + cryptography.
CALMA_SIGNING_KEY=
