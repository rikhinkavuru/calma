{
  "schema": "calma/recipe-draft@1",
  "metric_id": "coefficient_of_variation",
  "family": "stats",
  "description": "Coefficient of variation: sample std (ddof=1) over the mean. Relative dispersion; scale-invariant.",
  "program": {
    "schema": "calma/recipe-dsl@1",
    "inputs": {
      "value": "list"
    },
    "expr": {
      "op": "/",
      "args": [
        {
          "call": "fstd",
          "args": [
            {
              "col": "value"
            }
          ],
          "scalars": {
            "ddof": 1
          }
        },
        {
          "call": "fmean",
          "args": [
            {
              "col": "value"
            }
          ]
        }
      ]
    }
  },
  "generators": {
    "value": {
      "kind": "positive",
      "scale": 100.0
    }
  },
  "oracle": {
    "call": "scipy.stats.variation",
    "args": [
      "value"
    ],
    "kwargs": {
      "ddof": 1
    }
  },
  "metamorphic": [
    {
      "relation": "permutation",
      "expect": "equal"
    },
    {
      "relation": "scale",
      "factor": 7.0,
      "expect": "equal"
    },
    {
      "relation": "bounds",
      "min": 0
    }
  ],
  "edge_cases": {
    "empty": "nan",
    "single": "nan",
    "constant": 0,
    "nan": "nan"
  },
  "claim_hints": [
    "coefficient of variation",
    "relative std"
  ]
}