{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://calma.dev/recipe-draft/v1",
  "title": "calma recipe draft (the model's ONLY artifact - admission is deterministic)",
  "description": "What the drafting model emits, fully offline, under structured outputs. The admission gate (compiler.py) runs differential testing against the named oracle in the reference venv, the declared metamorphic relations, degeneracy/NaN checks, and a bit-stability double-run. Failures come back as counterexamples (CEGIS). The model is never consulted after admission.",
  "type": "object",
  "required": ["schema", "metric_id", "family", "description", "program", "generators", "oracle", "metamorphic", "edge_cases"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "calma/recipe-draft@1" },
    "metric_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "family": { "type": "string", "enum": ["quant", "classification", "regression", "analytics", "engineering", "retrieval", "llm-eval", "stats", "finance", "forecasting", "compiled"] },
    "description": { "type": "string", "maxLength": 300 },
    "program": {
      "type": "object",
      "required": ["schema", "inputs", "expr"],
      "additionalProperties": false,
      "properties": {
        "schema": { "const": "calma/recipe-dsl@1" },
        "inputs": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "enum": ["list", "rawlist"] }
        },
        "expr": { "$ref": "#/$defs/node" }
      }
    },
    "generators": {
      "type": "object",
      "description": "One deterministic LCG generator per program input. Must cover exactly the inputs.",
      "additionalProperties": {
        "type": "object",
        "required": ["kind"],
        "properties": {
          "kind": { "enum": ["uniform", "positive", "prob", "binary", "int", "category", "returns"] },
          "lo": { "type": "number" },
          "hi": { "type": "number" },
          "scale": { "type": "number" },
          "k": { "type": "integer", "minimum": 2 }
        }
      }
    },
    "oracle": {
      "type": "object",
      "description": "The published reference implementation the program must agree with, executed in the reference venv. e.g. {\"call\": \"scipy.stats.sem\", \"args\": [\"value\"], \"kwargs\": {\"ddof\": 1}}",
      "required": ["call", "args"],
      "additionalProperties": false,
      "properties": {
        "call": { "type": "string", "pattern": "^(numpy|scipy|sklearn|statsmodels|math|statistics)(\\.[A-Za-z_][A-Za-z0-9_]*)+$" },
        "args": { "type": "array", "items": { "type": "string" } },
        "kwargs": { "type": "object" }
      }
    },
    "metamorphic": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["relation"],
        "additionalProperties": false,
        "properties": {
          "relation": { "enum": ["permutation", "scale", "shift", "duplicate", "bounds"] },
          "expect": { "enum": ["equal", "linear", "quadratic", "shift-by-delta"] },
          "factor": { "type": "number" },
          "delta": { "type": "number" },
          "min": { "type": "number" },
          "max": { "type": "number" },
          "tags": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "edge_cases": {
      "type": "object",
      "description": "Required degradation behaviour. Values: \"nan\" (must degrade to NaN) or a number (must equal it). Cases not listed must still never raise and never return +-inf.",
      "additionalProperties": false,
      "properties": {
        "empty": { "$ref": "#/$defs/edge" },
        "single": { "$ref": "#/$defs/edge" },
        "constant": { "$ref": "#/$defs/edge" },
        "nan": { "$ref": "#/$defs/edge" }
      }
    },
    "claim_hints": {
      "type": "array",
      "description": "Phrases that bind a natural-language claim to this metric. Appended AFTER every built-in hint (most-specific-first ordering is preserved).",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "edge": { "oneOf": [{ "const": "nan" }, { "type": "number" }] },
    "node": {
      "oneOf": [
        { "type": "object", "required": ["col"], "additionalProperties": false,
          "properties": { "col": { "type": "string" } } },
        { "type": "object", "required": ["lit"], "additionalProperties": false,
          "properties": { "lit": { "type": "number" } } },
        { "type": "object", "required": ["call"], "additionalProperties": false,
          "properties": {
            "call": { "type": "string" },
            "args": { "type": "array", "items": { "$ref": "#/$defs/node" } },
            "scalars": { "type": "object", "additionalProperties": { "type": "number" } } } },
        { "type": "object", "required": ["op", "args"], "additionalProperties": false,
          "properties": {
            "op": { "enum": ["+", "-", "*", "/", "neg", "abs", "sqrt", "log", "exp", "min", "max"] },
            "args": { "type": "array", "items": { "$ref": "#/$defs/node" }, "minItems": 1, "maxItems": 2 } } },
        { "type": "object", "required": ["zip", "args"], "additionalProperties": false,
          "properties": {
            "zip": { "enum": ["+", "-", "*", "/"] },
            "args": { "type": "array", "items": { "$ref": "#/$defs/node" }, "minItems": 2, "maxItems": 2 } } },
        { "type": "object", "required": ["len"], "additionalProperties": false,
          "properties": { "len": { "$ref": "#/$defs/node" } } }
      ]
    }
  }
}
